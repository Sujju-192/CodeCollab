# Frontend environment variables (Vercel)
# Copy to frontend/.env for local development
# All VITE_ prefixed vars are exposed to the browser — never put secrets here

# Backend API (Render URL in production)
VITE_API_BASE_URL=http://localhost:3000

# Socket.IO (same as API URL — backend serves both on one port)
VITE_SOCKET_URL=http://localhost:3000

# Firebase (your new Firebase project)
VITE_FIREBASE_API_KEY=your_firebase_api_key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id
VITE_FIREBASE_APP_ID=your_firebase_app_id
VITE_FIREBASE_MEASUREMENT_ID=your_measurement_id

# Liveblocks (collaborative editing)
VITE_LIVEBLOCKS_PUBLIC_KEY=your_liveblocks_public_key

# AI panel (GitHub token stays on backend only)
VITE_AI_ENABLED=true
